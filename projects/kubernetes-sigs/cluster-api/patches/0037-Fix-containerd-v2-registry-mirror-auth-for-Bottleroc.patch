@@ -440,6 +443,50 @@ func parseTaints(taints []corev1.Taint) string {
 	return taintsToml.String()
 }
 
+// registryMirrorHostsTomlFile generates a write_files entry for the bootstrap
+// container cloud-config that writes hosts.toml with inline authorization headers.
+// This is needed because containerd v2 does not read credentials.toml from certs.d.
+// Returns nil if no credentials are configured.
+func registryMirrorHostsTomlFile(config *BottlerocketConfig) *bootstrapv1.File {
+	if config.RegistryMirrorCredentials.Username == "" || config.RegistryMirrorCredentials.Password == "" {
+		return nil
+	}
+	if config.RegistryMirrorConfiguration.Endpoint == "" && len(config.RegistryMirrorConfiguration.Mirrors) == 0 {
+		return nil
+	}
+
+	credEncoded := base64.StdEncoding.EncodeToString(
+		[]byte(fmt.Sprintf("%s:%s", config.RegistryMirrorCredentials.Username, config.RegistryMirrorCredentials.Password)))
+
+	var content strings.Builder
+	content.WriteString("server = \"https://public.ecr.aws\"\n")
+
+	endpoint := config.RegistryMirrorConfiguration.Endpoint
+	if len(config.RegistryMirrorConfiguration.Mirrors) > 0 {
+		for _, mirror := range config.RegistryMirrorConfiguration.Mirrors {
+			for _, ep := range mirror.Endpoints {
+				content.WriteString(fmt.Sprintf("\n[host.\"%s\"]\n", ep))
+				content.WriteString("  capabilities = [\"pull\", \"resolve\"]\n")
+				content.WriteString(fmt.Sprintf("\n[host.\"%s\".header]\n", ep))
+				content.WriteString(fmt.Sprintf("  authorization = \"Basic %s\"\n", credEncoded))
+			}
+		}
+	} else if endpoint != "" {
+		content.WriteString(fmt.Sprintf("\n[host.\"https://%s\"]\n", endpoint))
+		content.WriteString("  capabilities = [\"pull\", \"resolve\"]\n")
+		content.WriteString(fmt.Sprintf("\n[host.\"https://%s\".header]\n", endpoint))
+		content.WriteString(fmt.Sprintf("  authorization = \"Basic %s\"\n", credEncoded))
+	}
+
+	permissions := "0644"
+	return &bootstrapv1.File{
+		Path:        "/etc/containerd/certs.d/public.ecr.aws/hosts.toml",
+		Owner:       "root:root",
+		Permissions: permissions,
+		Content:     content.String(),
+	}
+}
+
