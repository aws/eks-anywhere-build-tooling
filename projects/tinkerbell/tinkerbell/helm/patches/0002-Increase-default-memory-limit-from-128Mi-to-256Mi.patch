From 0ce7c7d5c7f2ee28567f8da504c77d419bdaf190 Mon Sep 17 00:00:00 2001
From: Amelia Lu <63176721+peirulu@users.noreply.github.com>
Date: Fri, 10 Jul 2026 16:02:28 -0700
Subject: [PATCH 2/2] Increase default memory limit from 128Mi to 256Mi

The consolidated tinkerbell deployment runs all 5 services (smee,
tootles, tink-server, tink-controller, rufio) in a single pod.
The 128Mi limit is insufficient — baseline memory usage exceeds it,
causing OOMKill (exit 137) during upgrades. Bump to 256Mi.

Signed-off-by: Amelia Lu <peirulu@amazon.com>
---
 helm/tinkerbell/values.yaml | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/helm/tinkerbell/values.yaml b/helm/tinkerbell/values.yaml
index 0b3b5975..20c8b921 100644
--- a/helm/tinkerbell/values.yaml
+++ b/helm/tinkerbell/values.yaml
@@ -156,10 +156,10 @@ deployment:
   resources:
     limits:
       cpu: 500m
-      memory: 128Mi
+      memory: 256Mi
     requests:
       cpu: 500m
-      memory: 128Mi
+      memory: 256Mi
   selector: {}
   strategy:
     type: RollingUpdate
-- 
2.48.1

