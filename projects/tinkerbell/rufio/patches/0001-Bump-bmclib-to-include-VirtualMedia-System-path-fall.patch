From 1ffc6e31be102e2492789cfe4d4a13a177200803 Mon Sep 17 00:00:00 2001
From: Rahul Ganesh <rahulgab@amazon.com>
Date: Mon, 2 Mar 2026 22:17:34 +0000
Subject: [PATCH] Bump bmclib to include VirtualMedia System path fallback

Update bmclib/v2 to pick up bmc-toolbox/bmclib#433 which adds a
fallback to the Redfish System path for VirtualMedia discovery,
fixing ISO mounts on Dell iDRAC 10+.

Signed-off-by: Rahul Ganesh <rahulgab@amazon.com>
---
 go.mod | 2 +-
 go.sum | 4 ++--
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/go.mod b/go.mod
index fe4bd66..1a94796 100644
--- a/go.mod
+++ b/go.mod
@@ -6,7 +6,7 @@ toolchain go1.22.2
 
 require (
 	dario.cat/mergo v1.0.1
-	github.com/bmc-toolbox/bmclib/v2 v2.3.5-0.20251010091507-63cb571e5597
+	github.com/bmc-toolbox/bmclib/v2 v2.3.5-0.20260228062331-d87b1bea0e87
 	github.com/ccoveille/go-safecast v1.5.0
 	github.com/go-logr/logr v1.4.2
 	github.com/go-logr/zerologr v1.2.3
