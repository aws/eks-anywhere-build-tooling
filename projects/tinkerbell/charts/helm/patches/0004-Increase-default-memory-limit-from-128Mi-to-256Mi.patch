From 2aac3312412c3a6e5a2750fe8e299371534d7beb Mon Sep 17 00:00:00 2001
From: Amelia Lu <63176721+peirulu@users.noreply.github.com>
Date: Fri, 10 Jul 2026 14:00:28 -0700
Subject: [PATCH] Increase default memory limit from 128Mi to 256Mi

Tinkerbell pods OOMKill during upgrades because baseline memory usage
(~136Mi) exceeds the 128Mi limit. Bump to 256Mi for all components.

Signed-off-by: Amelia Lu <peirulu@amazon.com>
---
 tinkerbell/hegel/values.yaml | 2 +-
 tinkerbell/rufio/values.yaml | 2 +-
 tinkerbell/smee/values.yaml  | 2 +-
 tinkerbell/tink/values.yaml  | 4 ++--
 4 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/tinkerbell/hegel/values.yaml b/tinkerbell/hegel/values.yaml
index da85b26..a30fa7a 100644
--- a/tinkerbell/hegel/values.yaml
+++ b/tinkerbell/hegel/values.yaml
@@ -11,7 +11,7 @@ deployment:
 resources:
   limits:
     cpu: 500m
-    memory: 128Mi
+    memory: 256Mi
   requests:
     cpu: 10m
     memory: 64Mi
diff --git a/tinkerbell/rufio/values.yaml b/tinkerbell/rufio/values.yaml
index 13bdfaf..0c22731 100644
--- a/tinkerbell/rufio/values.yaml
+++ b/tinkerbell/rufio/values.yaml
@@ -8,7 +8,7 @@ resources:
     memory: 64Mi
   limits:
     cpu: 500m
-    memory: 128Mi
+    memory: 256Mi
 additionalArgs: []
 serviceAccountName: rufio-controller-manager
 rufioLeaderElectionRoleName: rufio-leader-election-role
diff --git a/tinkerbell/smee/values.yaml b/tinkerbell/smee/values.yaml
index 0bda77c..72c14aa 100644
--- a/tinkerbell/smee/values.yaml
+++ b/tinkerbell/smee/values.yaml
@@ -15,7 +15,7 @@ replicas: 1
 resources:
   limits:
     cpu: 500m
-    memory: 128Mi
+    memory: 256Mi
   requests:
     cpu: 10m
     memory: 64Mi
diff --git a/tinkerbell/tink/values.yaml b/tinkerbell/tink/values.yaml
index 7b896e7..20f1f6a 100644
--- a/tinkerbell/tink/values.yaml
+++ b/tinkerbell/tink/values.yaml
@@ -8,7 +8,7 @@ controller:
   resources:
     limits:
       cpu: 500m
-      memory: 128Mi
+      memory: 256Mi
     requests:
       cpu: 10m
       memory: 64Mi
@@ -38,7 +38,7 @@ server:
   resources:
     limits:
       cpu: 500m
-      memory: 128Mi
+      memory: 256Mi
     requests:
       cpu: 10m
       memory: 64Mi
-- 
2.48.1

