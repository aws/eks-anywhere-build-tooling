From 937be44332d6e867756a34ec130ccb39c48fcd47 Mon Sep 17 00:00:00 2001
From: Amelia Lu <peirulu@amazon.com>
Date: Wed, 17 Jun 2026 23:49:32 -0700
Subject: [PATCH] Replace redis/go-redis extra module versions with valid tags

The redis/go-redis monorepo does not have tags for extra/redisotel/v9.5.3
and extra/rediscmd/v9.5.3. Replace with v9.5.5 which is the nearest
available tagged version.
---
 go.mod | 6 +++++-
 go.sum | 8 ++++----
 2 files changed, 9 insertions(+), 5 deletions(-)

diff --git a/go.mod b/go.mod
index 87ea2a0f..ab1eb49f 100644
--- a/go.mod
+++ b/go.mod
@@ -4,6 +4,10 @@ go 1.26.0
 
 replace github.com/fluxcd/source-controller/api => ./api
 
+replace github.com/redis/go-redis/extra/redisotel/v9 v9.5.3 => github.com/redis/go-redis/extra/redisotel/v9 v9.5.5
+
+replace github.com/redis/go-redis/extra/rediscmd/v9 v9.5.3 => github.com/redis/go-redis/extra/rediscmd/v9 v9.5.5
+
 // Replace digest lib to master to gather access to BLAKE3.
 // xref: https://github.com/opencontainers/go-digest/pull/66
 replace github.com/opencontainers/go-digest => github.com/opencontainers/go-digest v1.0.1-0.20220411205349-bde1400a84be
@@ -317,7 +321,7 @@ require (
 	github.com/prometheus/common v0.67.5 // indirect
 	github.com/prometheus/otlptranslator v1.0.0 // indirect
 	github.com/prometheus/procfs v0.20.1 // indirect
-	github.com/redis/go-redis/extra/rediscmd/v9 v9.5.3 // indirect
+	github.com/redis/go-redis/extra/rediscmd/v9 v9.5.5 // indirect
 	github.com/redis/go-redis/extra/redisotel/v9 v9.5.3 // indirect
 	github.com/redis/go-redis/v9 v9.18.0 // indirect
 	github.com/rs/xid v1.6.0 // indirect
diff --git a/go.sum b/go.sum
index 76834c42..8abff6e4 100644
--- a/go.sum
+++ b/go.sum
@@ -879,10 +879,10 @@ github.com/prometheus/procfs v0.0.2/go.mod h1:TjEm7ze935MbeOT/UhFTIMYKhuLP4wbCsT
