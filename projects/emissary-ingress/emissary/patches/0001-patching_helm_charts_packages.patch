+                format: int32
+                maximum: 65535
+                minimum: 1
+                type: integer
+              protocol:
+                description: Protocol is a shorthand for certain predefined stacks.
+                  Exactly one of Protocol or ProtocolStack must be supplied.
+                enum:
+                - HTTP
+                - HTTPS
+                - HTTPPROXY
+                - HTTPSPROXY
+                - TCP
+                - TLS
+                - UDP
+                type: string
+              protocolStack:
+                description: ProtocolStack explicitly specifies the protocol stack to
+                  set up. Exactly one of Protocol or ProtocolStack must be supplied.
+                items:
+                  description: ProtocolStackElement defines specific layers that may
